{
  "title": "URL Shortener — Observability",
  "uid": "url-shortener-obs",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "rate(http_requests_total{job=\"url-shortener\"}[1m])",
          "legendFormat": "{{method}} {{path}} {{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Latency P99 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket{job=\"url-shortener\"}[1m]))",
          "legendFormat": "p99 {{path}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus" },
          "expr": "100 * rate(http_requests_total{job=\"url-shortener\", status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"url-shortener\"}[5m])"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 4,
      "title": "Logs (url-shortener)",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "loki" },
          "expr": "{service=\"url-shortener\"}"
        }
      ]
    }
  ]
}
